<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Ayo Tebak by OpangDarmawan</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@700;900&display=swap');

        :root {
            --bg-color: #ffde59;
            --primary: #ff3b3b;
            --secondary: #00d4ff;
            --success: #32cd32;
            --dark: #111111;
            --light: #ffffff;
            --warning: #ffaa00;
            --kocak-purple: #b5179e;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-color);
            background-image: 
                radial-gradient(circle at 20% 30%, var(--secondary) 10px, transparent 11px),
                radial-gradient(circle at 80% 70%, var(--kocak-purple) 15px, transparent 16px),
                radial-gradient(var(--primary) 15%, transparent 16%);
            background-size: 100px 100px, 80px 80px, 40px 40px;
            background-position: 0 0, 20px 20px, 0 0;
            font-family: 'Nunito', sans-serif;
            color: var(--dark);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            animation: bgScroll 20s linear infinite;
        }

        @keyframes bgScroll {
            0% { background-position: 0 0, 20px 20px, 0 0; }
            100% { background-position: 200px 200px, -200px 200px, 100px 100px; }
        }

        #game-container {
            width: 100%;
            max-width: 480px;
            height: 100%;
            max-height: 850px;
            background: var(--light);
            border: 8px solid var(--dark);
            border-radius: 30px;
            box-shadow: 15px 15px 0px var(--dark);
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            transform: rotate(-1deg);
            transition: transform 0.3s;
        }

        #game-container:hover {
            transform: rotate(0deg);
        }

        .screen {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            padding: 20px;
            text-align: center;
            animation: fadeIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .screen.active {
            display: flex;
        }

        h1, h2, h3 {
            font-family: 'Fredoka One', cursive;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 3px 3px 0px #fff, 6px 6px 0px var(--dark);
        }

        .title {
            font-size: 3.2rem;
            color: var(--primary);
            margin-bottom: 5px;
            line-height: 1;
            transform: rotate(-3deg);
        }

        .author {
            font-size: 1.3rem;
            background: var(--kocak-purple);
            color: var(--light);
            padding: 8px 20px;
            border-radius: 25px;
            margin-bottom: 30px;
            transform: rotate(4deg);
            border: 4px solid var(--dark);
            box-shadow: 5px 5px 0px var(--secondary);
            font-weight: 900;
        }

        .emoji-mascot {
            font-size: 6rem;
            margin-bottom: 10px;
            animation: crazyBounce 2s infinite alternate;
        }

        @keyframes crazyBounce {
            0% { transform: translateY(0) rotate(0deg) scale(1); }
            50% { transform: translateY(-25px) rotate(15deg) scale(1.1); }
            100% { transform: translateY(0) rotate(-15deg) scale(0.9); }
        }

        .btn {
            font-family: 'Fredoka One', cursive;
            font-size: 1.3rem;
            padding: 15px 25px;
            margin: 10px;
            width: 90%;
            background: var(--secondary);
            color: var(--dark);
            border: 5px solid var(--dark);
            border-radius: 15px;
            box-shadow: 6px 6px 0px var(--dark);
            cursor: pointer;
            transition: all 0.1s;
            text-transform: uppercase;
        }

        .btn:active {
            transform: translate(6px, 6px);
            box-shadow: 0px 0px 0px var(--dark);
        }

        .btn-primary { background: var(--primary); color: white; }
        .btn-success { background: var(--success); }
        .btn-warning { background: var(--warning); }
        .btn-purple { background: var(--kocak-purple); color: white; }

        .game-header {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            border-bottom: 6px solid var(--dark);
            background: var(--bg-color);
        }

        .level-badge {
            font-family: 'Fredoka One', cursive;
            font-size: 1.2rem;
            background: var(--light);
            padding: 8px 15px;
            border: 4px solid var(--dark);
            border-radius: 20px;
            box-shadow: 3px 3px 0px var(--dark);
            transform: rotate(-2deg);
        }

        .icon-btn {
            background: var(--light);
            border: 4px solid var(--dark);
            border-radius: 50%;
            width: 50px;
            height: 50px;
            font-size: 1.4rem;
            cursor: pointer;
            box-shadow: 4px 4px 0px var(--dark);
            display: flex;
            justify-content: center;
            align-items: center;
            transition: transform 0.1s;
        }
        
        .icon-btn:active {
            transform: translate(4px, 4px);
            box-shadow: 0px 0px 0px var(--dark);
        }

        .header-actions {
            display: flex;
            gap: 12px;
        }

        .question-box {
            background: #fff;
            border: 5px dashed var(--dark);
            border-radius: 20px;
            padding: 25px 20px;
            margin: 20px;
            font-size: 1.3rem;
            font-weight: 900;
            text-align: center;
            box-shadow: 8px 8px 0px var(--kocak-purple);
            position: relative;
            transform: rotate(1deg);
        }

        .question-box::before {
            content: '??';
            position: absolute;
            top: -20px;
            left: -10px;
            background: var(--warning);
            color: var(--dark);
            border: 3px solid var(--dark);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Fredoka One', cursive;
            transform: rotate(-15deg);
        }

        .options-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
            width: 100%;
            padding: 0 20px 20px 20px;
            flex-grow: 1;
            align-content: start;
            overflow-y: auto;
        }

        .option-btn {
            font-family: 'Nunito', sans-serif;
            font-weight: 900;
            font-size: 1.15rem;
            background: white;
            color: var(--dark);
            border: 4px solid var(--dark);
            border-radius: 12px;
            padding: 15px;
            text-align: left;
            cursor: pointer;
            box-shadow: 5px 5px 0px var(--dark);
            transition: all 0.1s;
            position: relative;
        }

        .option-btn:hover {
            background: #f0f0f0;
            transform: translateX(5px);
        }

        .option-btn:active {
            transform: translate(5px, 5px);
            box-shadow: 0px 0px 0px var(--dark);
        }

        .modal-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(17, 17, 17, 0.85);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 100;
            backdrop-filter: blur(5px);
        }

        .modal-content {
            background: white;
            border: 8px solid var(--dark);
            border-radius: 25px;
            padding: 30px 20px;
            text-align: center;
            width: 85%;
            max-height: 90%;
            overflow-y: auto;
            box-shadow: 10px 10px 0px var(--secondary);
            animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            transform: rotate(random(-2deg, 2deg));
        }

        .modal-title {
            font-size: 2rem;
            margin-bottom: 10px;
            line-height: 1.1;
        }

        .modal-text {
            font-size: 1.2rem;
            margin-bottom: 25px;
            font-weight: 900;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }

        @keyframes popIn {
            from { transform: scale(0); opacity: 0; }
            80% { transform: scale(1.1); opacity: 1; }
            to { transform: scale(1); opacity: 1; }
        }

        @keyframes shakeExtreme {
            0%, 100% { transform: translateX(0) rotate(0deg); }
            10%, 30%, 50%, 70%, 90% { transform: translateX(-15px) rotate(-3deg); }
            20%, 40%, 60%, 80% { transform: translateX(15px) rotate(3deg); }
        }

        .shake {
            animation: shakeExtreme 0.5s ease-in-out;
            background-color: var(--primary) !important;
            color: white !important;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--light);
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: var(--dark);
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <div id="game-container">
        
        <!-- Screen 1: Start Menu -->
        <div id="start-screen" class="screen active">
            <div class="emoji-mascot">🤪🧠</div>
            <h1 class="title">AYO<br>TEBAK!</h1>
            <div class="author">by OpangDarmawan</div>
            <div style="background: var(--dark); color: var(--warning); padding: 10px; border-radius: 10px; border: 3px dashed var(--warning); margin-bottom: 20px; font-weight: bold;">
                <p>⚠️ MODE EXTREME ⚠️</p>
                <p>5 Level | 25 Pertanyaan Rumit</p>
                <p>Tanpa Clue. Otakmu diuji!</p>
            </div>
            <button class="btn btn-primary" onclick="startGame()">Gas Main!</button>
        </div>

        <!-- Screen 2: Game Area -->
        <div id="game-screen" class="screen" style="padding:0; justify-content: start;">
            <div class="game-header">
                <div class="level-badge" id="level-display">Lv 1 - Soal 1/5</div>
                <div class="header-actions">
                    <button class="icon-btn" onclick="showPauseModal()" title="Pause">⏸️</button>
                    <button class="icon-btn" onclick="confirmRestart()" title="Ulangi">🔄</button>
                </div>
            </div>
            
            <div class="emoji-mascot" id="question-emoji" style="font-size: 4rem; margin-top: 15px; margin-bottom: 0; animation: none;">🤔</div>
            
            <div class="question-box" id="question-text">
                Pertanyaan rumit akan muncul di sini...
            </div>

            <div class="options-grid" id="options-container">
                <!-- Opsi digenerate via JS -->
            </div>
        </div>

        <!-- Screen 3: Tamat / End Game -->
        <div id="end-screen" class="screen">
            <div class="emoji-mascot" style="font-size: 6rem; animation: crazyBounce 1s infinite;">🤯🏆</div>
            <h1 class="title" style="font-size: 3.5rem; color: var(--success);">TAMAT!</h1>
            <p style="font-size: 1.3rem; font-weight: 900; margin: 15px; text-align: center; border: 4px solid var(--dark); padding: 15px; border-radius: 15px; background: #fff;">
                Sumpah, otak lu terbuat dari apa?! <br>Lu berhasil jawab 25 tebakan gak ngotak ini!<br><br>Salam super dari OpangDarmawan!
            </p>
            <button class="btn btn-purple" onclick="restartGame()">Mulai Ulang (Soal Beda Lho!)</button>
        </div>

        <!-- Modal Pause -->
        <div id="pause-modal" class="modal-overlay">
            <div class="modal-content">
                <div style="font-size: 4rem; margin-bottom: 10px;">😴☕</div>
                <h2 class="modal-title" style="color: var(--secondary);">PAUSE DULU</h2>
                <p class="modal-text">Napas woy! Jangan tegang amat mukanya. Minum kopi dulu gih.</p>
                <button class="btn btn-success" onclick="resumeGame()">Lanjut Main</button>
                <button class="btn btn-primary" onclick="confirmRestart()">Mulai dari Awal</button>
            </div>
        </div>

        <!-- Modal Confirm Restart -->
        <div id="confirm-restart-modal" class="modal-overlay">
            <div class="modal-content" style="border-color: var(--primary);">
                <div style="font-size: 4rem; margin-bottom: 10px;">🤨🏳️</div>
                <h2 class="modal-title" style="color: var(--primary);">NYERAH NIH?</h2>
                <p class="modal-text">Yakin mau ngulang dari Level 1? Progress lu bakal hangus!</p>
                <button class="btn btn-warning" onclick="restartGame()">Iya, Pusing Gue!</button>
                <button class="btn btn-success" onclick="closeModals()">Eh Nggak Jadi Deng</button>
            </div>
        </div>

        <!-- Modal Level Up -->
        <div id="levelup-modal" class="modal-overlay">
            <div class="modal-content" style="border-color: var(--kocak-purple);">
                <div style="font-size: 5rem; margin-bottom: 10px;">🚀🔥</div>
                <h2 class="modal-title" style="color: var(--kocak-purple);">LEVEL NAIK!</h2>
                <p class="modal-text">Hoki aja lu bang! Siap buat 5 soal yang lebih ngeselin?</p>
                <button class="btn btn-purple" onclick="nextLevel()">GAS TERUS!</button>
            </div>
        </div>

        <!-- Modal Feedback (Benar/Salah) -->
        <div id="feedback-modal" class="modal-overlay">
            <div class="modal-content" id="feedback-content">
                <div id="feedback-emoji" style="font-size: 5rem; margin-bottom: 10px;">✅</div>
                <h2 class="modal-title" id="feedback-title">BENER KOCOK!</h2>
                <!-- Penjelasan tetap ada untuk menambah kelucuan setelah menebak -->
                <p class="modal-text" id="feedback-message" style="background: var(--bg-color); padding: 10px; border-radius: 10px; border: 2px solid var(--dark);">Penjelasan jawaban.</p>
                <button class="btn btn-success" id="feedback-btn" onclick="nextQuestion()">Lanjut Bang!</button>
            </div>
        </div>

    </div>

    <!-- STREAMING_CHUNK: Inisialisasi Database Soal yang SANGAT BANYAK (>65 Soal)... -->
    <script>
        // Pilihan pertama (index 0) di array 'opts' ADALAH JAWABAN BENAR.
        // Sistem nanti akan mengacak posisinya secara otomatis. TIDAK ADA CLUE di soal.
        const rawQuestions = [
            { emoji: "🐘", q: "Gajah terbang dengan apa?", opts: ["Dengan susah payah", "Sayap", "Baling-baling bambu", "Bantuan doa ibu"], f: "Ya iyalah, gajah segede gaban disuruh terbang, pasti susah payah!" },
            { emoji: "🐟", q: "Ikan apa yang matanya ada banyak banget?", opts: ["Ikan teri sekilo", "Ikan mata-mata", "Ikan mutan", "Ikan kurang tidur"], f: "Coba aja lu beli teri sekilo, hitung deh matanya ada berapa tuh." },
            { emoji: "🍎", q: "Buah apa yang paling rajin, disiplin, dan gak pernah telat?", opts: ["Apel pagi", "Pisang goreng", "Buah hati", "Jeruk peras"], f: "Siap grak! Apel pagi dimulai! Laporan selesai." },
            { emoji: "🥤", q: "Minum es teh manis. Pas esnya udah habis, sisanya apa?", opts: ["Sisa bayarnya", "Sisa es batu", "Sisa manisnya", "Sisa kenangan"], f: "Heh, jangan ngutang woy! Es abis ya tinggal bayarnya ke Mang Kasir." },
            { emoji: "🐃", q: "Kebo apa yang bikin capek banget sampe ngos-ngosan?", opts: ["Kebogor jalan kaki", "Kebo ngamuk", "Kebo bunting", "Kebobolan gawang"], f: "Dari Jakarta ke Bogor jalan kaki... Gempor dah tuh kaki." },
            { emoji: "🚪", q: "Pintu apa yang didorong 10 orang pun gak bakal bisa kebuka?", opts: ["Pintu yang ada tulisan TARIK", "Pintu brankas bank", "Pintu hatimu", "Pintu ajaib Doraemon"], f: "Udah tau tulisannya TARIK, ngapain lu dorong rame-rame malih?!" },
            { emoji: "🌴", q: "Kenapa pohon kelapa di depan rumah harus ditebang?", opts: ["Kalo dicabut berat bang", "Nutupin jalan", "Biar terang", "Takut jatuh nimpa rumah"], f: "Bener kan? Coba aja lu cabut pohon kelapa pake tangan kosong kalo bisa." },
            { emoji: "👟", q: "Benda apa yang kalo diikat baru bisa jalan?", opts: ["Sepatu", "Sandera", "Kuda lumping", "Layang-layang"], f: "Tali sepatunya diikat dulu bos biar gak nyusruk pas jalan." },
            { emoji: "🐔", q: "Ayam apa yang dicari-cari tapi pas ketemu gak mau dimakan?", opts: ["Ayam hilang", "Ayam cemani", "Ayam kampus", "Ayam tetangga"], f: "Kalo ayam lu peliharaan hilang pasti dicariin, tapi masa iya pas ketemu langsung digoreng?" },
            { emoji: "🥣", q: "Apa bedanya Soto sama Siti?", opts: ["Soto pake daging, Siti pake jilbab", "Soto panas, Siti dingin", "Soto kuah, Siti kering", "Gak ada bedanya"], f: "Ya bener sih, lu emang pernah liat soto pake jilbab?" },
            { emoji: "🦸‍♂️", q: "Kenapa di dada Superman ada huruf S?", opts: ["Karena kalo pakai M atau XL kebesaran", "Karena dia Super", "Karena Singkatan namanya", "Karena dia Suka begadang"], f: "Baju superhero juga ada ukurannya kali bang, S = Small." },
            { emoji: "🚗", q: "Mobil apa yang bikin galau dan bimbang?", opts: ["Mobilang sayang tapi takut ditolak", "Mobil mogok", "Mobil jenazah", "Mobil tetangga yang lebih bagus"], f: "Duh... kasihan amat mblo, nyatakan aja napa." },
            { emoji: "👀", q: "Jauh di mata, tapi sangat dekat di hati. Apakah itu?", opts: ["Usus", "Mantan", "Hutang", "Pacar orang"], f: "Coba lu liat anatomi tubuh, mata di kepala, usus nyender di bawah hati wkwk." },
            { emoji: "🐎", q: "Kuda apa yang bikin capek?", opts: ["Kudaki gunung lewati lembah", "Kuda poni", "Kuda lumping", "Kuda catur"], f: "Nyanyi woy Ninja Hatori! Hati gembira..." },
            { emoji: "🦇", q: "Lele apa yang bisa terbang?", opts: ["Lelelawar", "Lele dumbo", "Lelelaba", "Lele super"], f: "Emang agak maksa sih bang, tapi masuk akal kan?" },
            { emoji: "👂", q: "Daun apa yang gak pernah gugur dari dulu?", opts: ["Daun telinga", "Daun pisang", "Daun jati", "Daun kemangi"], f: "Kalo daun telinga lu gugur, denger pake apa ntar?" },
            { emoji: "🐜", q: "Hewan apa yang paling hening di dunia?", opts: ["Semute (Mute)", "Jangkrik", "Ular", "Kura-kura"], f: "Tombol mute dipencet jadi sunyi senyap dah." },
            { emoji: "🐊", q: "Buah apa yang bikin takut cewek-cewek?", opts: ["Buahaya", "Buah naga", "Buah durian", "Buah simalakama"], f: "Awas digigit buahaya darat yang suka nongkrong di cafe!" },
            { emoji: "💊", q: "Benda apa yang huruf depannya K belakangnya L?", opts: ["Kapsul", "Kapal", "Kutil", "Knalpot"], f: "Minum kapsul gih biar otak lancar ngerjain tebakan ginian." },
            { emoji: "🌶️", q: "Ban apa yang sangat pedas dan enak dimakan?", opts: ["Bandeng balado", "Ban bocor", "Banteng", "Ban mobil tronton"], f: "Pake nasi anget mantap banget tuh bang." },
            { emoji: "🐌", q: "Siput apa yang kemana-mana selalu bawa kera?", opts: ["Siputa dari gua hantu", "Siput sawah", "Siput ninja", "Siput gila"], f: "Si Barda bawa tongkat sama monyet ke mana-mana, legend nih!" },
            { emoji: "🐍", q: "Belut apa yang paling berbahaya dan ngeselin?", opts: ["Belutang banyak tapi gak bayar", "Belut listrik", "Belut raksasa", "Belut sawah"], f: "Ditagih hutang malah lebih galak dia, ampun dah." },
            { emoji: "🐻", q: "Hewan apa yang paling kaya raya se-hutan?", opts: ["Beruang", "Singa", "Harimau", "Burung gereja"], f: "Namanya aja 'Ber-uang', pasti sultan dia bos." },
            { emoji: "🧼", q: "Sabun apa yang paling genit?", opts: ["Sabun colek", "Sabun mandi", "Sabun cair", "Sabun batangan"], f: "Colek-colek mulu kerjaannya kayak abang-abang iseng." },
            { emoji: "🚿", q: "Kuman apa yang paling bersih dan wangi?", opts: ["Kumandi pakai sabun", "Kuman air", "Kuman mati", "Kuman baik"], f: "Kalo udah mandi ya wangi dong, wujudnya aja kuman." },
            { emoji: "🐴", q: "Kuda apa yang jalannya selalu miring?", opts: ["Kuda catur", "Kuda kepang", "Kuda binal", "Kuda laut"], f: "Kuda catur kan jalannya bentuk huruf L, ya pasti miring lah." },
            { emoji: "🏃", q: "Ular apa yang selalu sehat jasmani?", opts: ["Ular raga", "Ular kobra", "Ular sanca", "Ular piton"], f: "Tiap pagi jogging terus dia makanya bugar." },
            { emoji: "🏃‍♂️", q: "Tukang apa yang kalau dipanggil malah lari ngejauh?", opts: ["Tukang copet", "Tukang bakso", "Tukang ojek", "Tukang paket"], f: "Kalo dia nyamperin lu ya malah digebukin massa lah!" },
            { emoji: "👞", q: "Apa bedanya sepatu sama jengkol?", opts: ["Sepatu disemir, jengkol disemur", "Gak ada bedanya", "Sama-sama bikin bau", "Sepatu keras jengkol empuk"], f: "Sama-sama se- awalan katanya doang bedanya semir dan semur wkwk." },
            { emoji: "🚁", q: "Kopi apa yang paling cepat di dunia?", opts: ["Kopiloter", "Kopi hitam", "Kopi instan", "Kopi luwak"], f: "Baling-balingnya kenceng bang, melesat ke udara!" },
            { emoji: "🪵", q: "Kayu apa yang renyah dan enak dimakan pakai kuah?", opts: ["Kayupuk", "Kayu manis", "Kayu jati", "Kayu bakar"], f: "Kriuk kriuk pas makan soto ayam nih." },
            { emoji: "😵", q: "Minyak apa yang bikin nyesek dan galau?", opts: ["Minyaksikan kamu jalan sama dia", "Minyak telon", "Minyak goreng", "Minyak wangi"], f: "Awas netes tuh air mata, ambil tisu gih." },
            { emoji: "🥮", q: "Kue apa yang bungkusnya di dalam tapi isinya di luar?", opts: ["Kue salah bikin", "Kue lapis", "Kue cubit", "Kue talam"], f: "Tukang kuenya lagi ngantuk berat pas ngadonin kayaknya." },
            { emoji: "🎯", q: "Orang apa yang ditembak berkali-kali nggak bakal mati?", opts: ["Orang nggak kena", "Orang sakti", "Orang kebal", "Orang gila"], f: "Ya pelurunya meleset terus, gimana mau mati bos." },
            { emoji: "🕳️", q: "Benda apa yang masuknya miring keluarnya juga miring?", opts: ["Kancing baju", "Kepiting", "Ular", "Gergaji"], f: "Coba perhatiin aja pas lu lagi ngancingin kemeja." },
            { emoji: "🩴", q: "Sandal apa yang paling enak dan bikin kenyang?", opts: ["Sandala macem masakan padang", "Sandal jepit", "Sandal kulit", "Sandal hotel"], f: "Pake bumbu rendang, ayam pop, tunjang, mantap bener dah." },
            { emoji: "⛽", q: "Mobil apa yang gasnya ada di belakang?", opts: ["Mobil tukang jual gas", "Mobil balap", "Mobil mogok", "Mobil mundur"], f: "Bawa tabung melon di bak belakang banyak bener." },
            { emoji: "🦥", q: "Hewan apa yang keahliannya paling banyak?", opts: ["Kukang", "Anjing", "Monyet", "Lumba-lumba"], f: "Kukang sate, kukang parkir, kukang tambal ban, multitalenta dah." },
            { emoji: "🐦", q: "Burung apa yang suka nolak kalau disuruh terbang?", opts: ["Burung puyuh", "Burung unta", "Burung dara", "Burung hantu"], f: "Ah puyuh (nggak mau) ah, lagi capek pengen rebahan." },
            { emoji: "🇮🇩", q: "Coba hitung, di Indonesia ada berapa huruf U?", opts: ["Nggak ada", "Lima", "Satu", "Banyak"], f: "I-N-D-O-N-E-S-I-A. Coba lu cari huruf U-nya sampe botak." },
            { emoji: "👖", q: "Benda apa yang kalau dipotong malah makin panjang?", opts: ["Kacang panjang", "Celana", "Rambut", "Jalanan"], f: "Kalo dipotong sekecil apapun namanya tetep kacang panjang kan." },
            { emoji: "🐱", q: "Kucing apa yang sering disebut sama orang yang lagi putus asa?", opts: ["Kucingkurap", "Kucing gila", "Kucing oren", "Kucing garong"], f: "🎵 Ku hancur, ku hancur, kucingkurap... 🎵" },
            { emoji: "🌌", q: "Ayam apa yang ukurannya besar banget seluas galaksi?", opts: ["Ayam semesta", "Ayam pelung", "Ayam kalkun", "Ayam raksasa"], f: "Menyelimuti seluruh alam semesta raya ini bang." },
            { emoji: "👴", q: "Rambut putih uban, rambut merah pirang, kalau rambut hijau?", opts: ["Rambutan belum mateng", "Orang aneh", "Kena cat", "Cosplay anime"], f: "Asem banget tuh rambutannya jangan dimakan dulu dah." },
            { emoji: "🏦", q: "Bunga apa yang harganya paling mahal dan bikin pusing?", opts: ["Bunga bank", "Bunga mawar", "Bunga melati", "Bunga anggrek"], f: "Kalo bunganya makin gede, cicilan makin berat bang, puyeng." },
            { emoji: "👻", q: "Hantu apa yang jago banget matematika?", opts: ["Han-tuyul", "Pocong", "Kuntilanak", "Genderuwo"], f: "Jago ngitung segepok duit tetangga tuh dia." },
            { emoji: "🦎", q: "Negara apa yang selalu dihafal sama anak-anak TK?", opts: ["Cili", "Indonesia", "Malaysia", "Amerika"], f: "Cili-cili di dinding... (Cicak woy!)" },
            { emoji: "🏊", q: "Orang apa yang berenang tapi rambutnya gak basah?", opts: ["Orang botak", "Orang pakai topi", "Orang sakti", "Orang mainan"], f: "Licin bang, airnya langsung kepeleset kena pantulan cahaya." },
            { emoji: "🧟", q: "Kenapa zombie kalau nyerang manusia selalu bareng-bareng?", opts: ["Karena kalau sendiri namanya zomblo", "Karena takut", "Biar kuat", "Karena laper"], f: "Kasihan mana gak laku, makanya nongkrongnya banyakan." },
            { emoji: "👻", q: "Pocong apa yang paling disukai ibu-ibu komplek?", opts: ["Pocongan harga", "Pocong lucu", "Pocong pink", "Pocong bantal"], f: "Diskon 50% ibu-ibu langsung barbar serbu keranjang." },
            { emoji: "🐘", q: "Gajah apa yang belalainya sangat pendek?", opts: ["Gajah pesek", "Gajah mini", "Gajah mainan", "Gajah purba"], f: "Tulang hidungnya amblas ke dalem makanya pesek." },
            { emoji: "🏍️", q: "Sapi apa yang larinya cepet banget ngalahin mobil?", opts: ["Sapida motor", "Sapi gila", "Sapi balap", "Sapi liar"], f: "Suaranya ngeng ngeng ngeng... bukan mooo." },
            { emoji: "🏙️", q: "Kota apa yang nilainya selalu tujuh di raport?", opts: ["Salatiga", "Jakarta", "Surabaya", "Bandung"], f: "Kalo salah semua ya nol alias anjlok nilainya." },
            { emoji: "☀️", q: "Kenapa matahari kalau sore selalu tenggelam?", opts: ["Karena nggak bisa berenang", "Karena capek", "Udah malam", "Disuruh bulan"], f: "Kalo dia bisa gaya katak mah ngambang terus." },
            { emoji: "🚌", q: "Bis apa yang sering bikin orang mabuk dan menyesal?", opts: ["Bisikan sayang dari pacar orang", "Bis kota", "Bis pariwisata", "Biskuit"], f: "Bikin mual karena dihantui rasa bersalah di akhir wkwk." },
            // Tambahan Soal Ekstra agar total > 65
            { emoji: "🎤", q: "Penyanyi luar negeri yang susah banget nelen?", opts: ["Ed Kesedak", "Bruno Mars", "Justin Bieber", "Eminem"], f: "Ed Kesedak (Ed Sheeran)... minum air gih bang." },
            { emoji: "🥦", q: "Sayur apa yang jago nyanyi lagu rock alternatif?", opts: ["Kolplay", "Brokoli", "Bayam", "Kangkung"], f: "Fix You versi sayur kol, mantap." },
            { emoji: "⏰", q: "Benda apa yang kalau di balik pasti selalu rusak?", opts: ["Jam", "Gelas", "Piring", "Mobil"], f: "Jam dinding lu balik nutup ke tembok, ya gak keliatan angkanya, rusak fungsi." },
            { emoji: "🐸", q: "Hewan apa yang pasti saling bersaudara?", opts: ["Katak beradik", "Kucing garong", "Anjing pelacak", "Burung pipit"], f: "Kakak beradik... eh Katak beradik ding." },
            { emoji: "🤣", q: "Buah apa yang selalu bikin orang senang dan tertawa?", opts: ["Buahagia", "Buah pir", "Buah mangga", "Buah apel"], f: "Buahagia bersamamu selamanya eaa." },
            { emoji: "👮", q: "Polisi apa yang punya wilayah paling sempit sedunia?", opts: ["Polisi tidur", "Polisi lalu lintas", "Polisi hutan", "Polisi air"], f: "Cuma seukuran gundukan aspal doang kekuasaannya." },
            { emoji: "🎵", q: "Penyanyi Indonesia yang rambutnya gak pernah lurus?", opts: ["Ayu Keriting", "Ayu Ting Ting", "Raisa", "Isyana"], f: "Kalo lurus namanya bukan Ayu Keriting dong." },
            { emoji: "💉", q: "Penyakit apa yang paling terkenal di seluruh China?", opts: ["Kungflu", "Demam berdarah", "Tipes", "Masuk angin"], f: "Jurus bangau terbang sambil bersin-bersin. Haccihh!" },
            { emoji: "🍞", q: "Roti apa yang jahat banget dan bikin sakit hati?", opts: ["Roti tawar menawar", "Roti buaya", "Roti sobek", "Roti bakar"], f: "Udah dikasih harga murah masih aja ditawar sadis." },
            { emoji: "💇", q: "Tukang apa yang walau salah potong tetep aja dibayar?", opts: ["Tukang cukur", "Tukang kayu", "Tukang daging", "Tukang kain"], f: "Lu protes tetep aja harus bayar bang, gak bisa ditempel lagi tuh rambut." },
            { emoji: "☁️", q: "Awan apa yang paling bikin istri senyum lebar?", opts: ["Awang belanja bulanan", "Awan mendung", "Awan kinton", "Awan kumulus"], f: "Awang (Uang) belanja turun rintik-rintik ke dompet." },
            { emoji: "🐱", q: "Kenapa kucing kalau tidur matanya merem?", opts: ["Karena kalau melek namanya pura-pura tidur", "Karena silau", "Karena capek", "Biar nyenyak"], f: "Logika dasar woy, lu tidur mata melek serem amat." }
        ];

        let levelsData = [];
        let currentLevelIdx = 0; // 0 to 4 (5 Level)
        let currentQuestionIdx = 0; // 0 to 4 (5 Pertanyaan per Level)

        // Utility: Acak Array
        function shuffleArray(array) {
            let arr = [...array];
            for (let i = arr.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [arr[i], arr[j]] = [arr[j], arr[i]];
            }
            return arr;
        }

        // Generate 25 soal baru setiap game dimulai
        function generateRandomLevels() {
            let shuffledPool = shuffleArray(rawQuestions);
            let selectedQuestions = shuffledPool.slice(0, 25); // Ambil 25 soal persis
            
            let formattedQuestions = selectedQuestions.map(q => {
                let correctAnswerString = q.opts[0]; 
                let shuffledOptions = shuffleArray(q.opts);
                return {
                    emoji: q.emoji,
                    question: q.q,
                    options: shuffledOptions,
                    correctIndex: shuffledOptions.indexOf(correctAnswerString),
                    feedback: q.f
                };
            });

            // Bagi 25 soal ke dalam 5 Level (Masing-masing 5 soal)
            const levelTitles = ["Pemanasan Awal", "Mulai Pusing", "Otak Ngebul", "Bikin Emosi", "Level Dewa Gabut"];
            levelsData = [];
            
            for(let i = 0; i < 5; i++) {
                levelsData.push({
                    level: i + 1,
                    title: levelTitles[i],
                    questions: formattedQuestions.slice(i * 5, (i * 5) + 5)
                });
            }
        }

        const startScreen = document.getElementById('start-screen');
        const gameScreen = document.getElementById('game-screen');
        const endScreen = document.getElementById('end-screen');
        
        const levelDisplay = document.getElementById('level-display');
        const questionText = document.getElementById('question-text');
        const questionEmoji = document.getElementById('question-emoji');
        const optionsContainer = document.getElementById('options-container');
        
        const pauseModal = document.getElementById('pause-modal');
        const confirmRestartModal = document.getElementById('confirm-restart-modal');
        const feedbackModal = document.getElementById('feedback-modal');
        const levelupModal = document.getElementById('levelup-modal');
        
        const feedbackEmoji = document.getElementById('feedback-emoji');
        const feedbackTitle = document.getElementById('feedback-title');
        const feedbackMessage = document.getElementById('feedback-message');
        const feedbackBtn = document.getElementById('feedback-btn');

        function switchScreen(screenElement) {
            document.querySelectorAll('.screen').forEach(scr => scr.classList.remove('active'));
            screenElement.classList.add('active');
        }

        function startGame() {
            generateRandomLevels();
            currentLevelIdx = 0;
            currentQuestionIdx = 0;
            switchScreen(gameScreen);
            loadQuestion();
        }

        function loadQuestion() {
            const currentLevelData = levelsData[currentLevelIdx];
            const currentQ = currentLevelData.questions[currentQuestionIdx];
            
            levelDisplay.innerText = `Lv ${currentLevelData.level} - Soal ${currentQuestionIdx + 1}/5`;
            questionEmoji.innerText = currentQ.emoji;
            questionText.innerText = currentQ.question; // Tidak ada clue tambahan
            
            optionsContainer.innerHTML = '';
            
            currentQ.options.forEach((optionText, index) => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                btn.innerText = `${String.fromCharCode(65 + index)}. ${optionText}`;
                btn.onclick = () => checkAnswer(index, btn);
                optionsContainer.appendChild(btn);
            });
        }

        function checkAnswer(selectedIndex, buttonElement) {
            const currentLevelData = levelsData[currentLevelIdx];
            const currentQ = currentLevelData.questions[currentQuestionIdx];
            
            if (selectedIndex === currentQ.correctIndex) {
                // Jawaban Benar
                feedbackEmoji.innerText = "🤣✅";
                feedbackTitle.innerText = "BENER BANGET!";
                feedbackTitle.style.color = "var(--success)";
                feedbackMessage.innerText = currentQ.feedback;
                feedbackBtn.className = "btn btn-success";
                
                const isLastQuestionInLevel = (currentQuestionIdx === currentLevelData.questions.length - 1);
                const isLastLevel = (currentLevelIdx === levelsData.length - 1);

                if (isLastQuestionInLevel && isLastLevel) {
                    feedbackBtn.innerText = "Lihat Hasil Akhir!";
                    feedbackBtn.onclick = showEndScreen;
                } else if (isLastQuestionInLevel) {
                    feedbackBtn.innerText = "Tamat Level Ini!";
                    feedbackBtn.onclick = showLevelUpModal;
                } else {
                    feedbackBtn.innerText = "Lanjut Soal Berikutnya";
                    feedbackBtn.onclick = nextQuestion;
                }
                
                feedbackModal.style.display = "flex";
            } else {
                // Jawaban Salah
                buttonElement.classList.add('shake');
                setTimeout(() => buttonElement.classList.remove('shake'), 500);
                
                feedbackEmoji.innerText = "🗿❌";
                feedbackTitle.innerText = "SALAH KOCOK!";
                feedbackTitle.style.color = "var(--primary)";
                
                const wrongMessages = [
                    "Otak lu nyampe gak sih mikirin ginian?",
                    "Coba dibaca lagi, jangan asal klik doang woy!",
                    "Salah! Insting lu tumpul banget bang.",
                    "Terlalu serius mikirnya, pake logika bapak-bapak dong!",
                    "Nyerah aja mending kalo pusing."
                ];
                feedbackMessage.innerText = wrongMessages[Math.floor(Math.random() * wrongMessages.length)];
                
                feedbackBtn.className = "btn btn-primary";
                feedbackBtn.innerText = "Coba Tebak Lagi";
                feedbackBtn.onclick = () => { feedbackModal.style.display = "none"; };
                
                feedbackModal.style.display = "flex";
            }
        }

        function nextQuestion() {
            feedbackModal.style.display = "none";
            currentQuestionIdx++;
            loadQuestion();
        }

        function showLevelUpModal() {
            feedbackModal.style.display = "none";
            levelupModal.style.display = "flex";
        }

        function nextLevel() {
            levelupModal.style.display = "none";
            currentLevelIdx++;
            currentQuestionIdx = 0;
            loadQuestion();
        }

        function showEndScreen() {
            feedbackModal.style.display = "none";
            switchScreen(endScreen);
        }

        function showPauseModal() {
            pauseModal.style.display = "flex";
        }

        function resumeGame() {
            pauseModal.style.display = "none";
        }

        function confirmRestart() {
            pauseModal.style.display = "none";
            confirmRestartModal.style.display = "flex";
        }

        function closeModals() {
            pauseModal.style.display = "none";
            confirmRestartModal.style.display = "none";
            feedbackModal.style.display = "none";
            levelupModal.style.display = "none";
        }

        function restartGame() {
            closeModals();
            startGame();
        }
    </script>
</body>
</html>
